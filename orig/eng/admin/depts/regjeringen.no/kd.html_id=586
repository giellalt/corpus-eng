<script type="text/javascript">
//<![CDATA[
    function getPropertyFromArrayById(ar, id, prop) {
        for (var i = 0; i < ar.length; i++) {
            if (ar[i].id == id) {
                return decodeURIComponent(ar[i][prop]);
            }
        }
    }

    function parseLinkData(str) {
        var ar = str.split('¤');
        var output = new Object();
        output.imgurl = encodeURIComponent(ar[0]); //URL til rollover bilde
        output.alttekst = encodeURIComponent(ar[1].replace(/\"/g, '&quot;')); //Alternativ tekst for rollover bilde
        output.movieurl = ar[2]; //fluvi id
        output.fallback = ar[3]; //fallback bilde for flash
        output.baseurl = encodeURIComponent(ar[4]); //Url til plassering av player swf (http://minserver.no/player.swf)
        output.delay = ar[5]; //Tidsinterval for rullering av bilder (0 = av)
        output.phototext = encodeURIComponent(ar[6]); //Foto tekst under bilde/video
        output.linkurl = encodeURIComponent(ar[7]); // klikkbar link for bild
        output.id = "container" + parseInt(Math.random() * 1000000);
        return output;
    }

    function showImageById(id) {
        if (getPropertyFromArrayById(elems, id, 'movieurl') == 0) {
            // No video
            jQuery('.MediaContent').html('<a href="' + getPropertyFromArrayById(elems, id, 'linkurl') + '"> <img src="' + getPropertyFromArrayById(elems, id, 'fallback') + '" style="width:54em;height:30.4em;" alt="' + getPropertyFromArrayById(elems, id, 'alttekst') + '" title="' + getPropertyFromArrayById(elems, id, 'alttekst') + '" /></a>');
            jQuery('.MediaText').html(getPropertyFromArrayById(elems, id, 'alttekst'));
            jQuery('#'+id).find('a.tabLink').remove();
        } else {
            // Video: Create the image tag
            var obj = jQuery('.MediaContent');
            var objHtmlStr = '<a href="#">';
            objHtmlStr += '<div style="background-image: url(' + getPropertyFromArrayById(elems, id, 'fallback') + '); background-repeat: no-repeat;">';
            objHtmlStr += '<img title="' + getPropertyFromArrayById(elems, id, 'alttekst') + '" alt="' + getPropertyFromArrayById(elems, id, 'alttekst') + '" src="/images/fluvi/playbutton_540.png" style="position: relative;border:0px;" />';
            objHtmlStr += '</div>';
            objHtmlStr += '</a>';            
            obj.html(objHtmlStr);
            obj.find('a').data('objId', id).click(function (e) {
                var myId = jQuery(this).data('objId');
                if (!myId) return false;
                //Swap to video player				
                swapToPlayer(jQuery(this), myId);
                return false;
            });
        }
        //Swap between the images
        jQuery('.MediaContent > img').attr("src", getPropertyFromArrayById(elems, id, 'imgurl'));
        jQuery('.MediaContent > img').attr("id", getPropertyFromArrayById(elems, id, 'id'));
        jQuery('.MediaContent > img').attr("alt", getPropertyFromArrayById(elems, id, 'alttekst'));
        jQuery('.MediaText').html(getPropertyFromArrayById(elems, id, 'phototext'));
    }

    function swapToPlayer(el, myId, autoplay) {
        //Disable the rollover for all divs
        jQuery('#FocusBoxLeft > div').unbind('mouseover');
        //Stop rotating pictures
        window.clearInterval(rotateInterval);

        var movieUrl = getPropertyFromArrayById(elems, myId, 'baseurl');
        movieUrl += '&width=540&height=304';

        var height = 304;
        var width = 540;
        if (checkForIE7BrowserVersion()) {
            height += 2;
            width += 2;
        }
        var playHtml = '<iframe scrolling="no" frameborder="0" src="' + movieUrl + '" width="' + width + '" height="' + height + '">';
        playHtml += '<p>Your browser does not support iframes.</p>';
        playHtml += '</iframe>';
        
        el.parent().html(playHtml);
    }

    function checkForIE7BrowserVersion() {
        var ver = -1; 
        if (navigator.appName == 'Microsoft Internet Explorer') {
            var ua = navigator.userAgent;
            var re = new RegExp("MSIE ([0-9]{1,}[\.0-9]{0,})");
            if (re.exec(ua) != null)
                ver = parseFloat(RegExp.$1);
        }
        if (ver > -1) {
            if (ver > 6.0 && ver < 8.0) {
                return true;
            }
        }
        return false;
    }


    function showNextImage() {
        jQuery('#FocusBoxLeft > div').removeClass('highlight');
        jQuery('#FocusBoxLeft > div').eq(currentImageIndex).addClass('highlight');
        if (elems.length > 0) {
        showImageById(elems[currentImageIndex].id);
        if ((currentImageIndex < (elems.length - 1)) && rotateInterval > 0) {
            currentImageIndex++;
        } else {
            currentImageIndex = 0; //loop
        }
    }
    }

    function setHighlightForElement(elem) {
        jQuery('#FocusBoxLeft > div').removeClass('highlight');
        elem.addClass('highlight');
    }

    function mouseoverHandler() {
        switchTo(jQuery(this));
    }

    function switchTo(el) {
        window.clearInterval(rotateInterval); //Stop rotating pictures
        showImageById(el.attr('id'));
        setHighlightForElement(el);
    }

    function linkFocusHandler(e) {
        var $this = jQuery(this);
        switchTo($this.parents('.singleFocusBox'));
    }

    function init() {
        //SETUP
        var objects = jQuery('#FocusBoxLeft').children();
        for (var i = 0; i < objects.length; i++) {
            var thisData = parseLinkData(jQuery(objects[i]).attr('title'));
            thisData.linkurl = jQuery(objects[i]).find("h1 a:first").attr("href"); 
            elems.push(thisData);
            jQuery('#FocusBoxLeft > div').eq(i).attr('id', thisData.id);
        }
        jQuery('#FocusBoxLeft > div').removeAttr('title');

        jQuery('#FocusBoxLeft > div').bind('mouseover', mouseoverHandler);

        jQuery('#FocusBoxLeft a').bind('focus', linkFocusHandler);

        jQuery('body').keydown(function (e) {
            if (e.keyCode == 16) {   // 16 = Shift button
                shiftPressed = true;
            }
        });
        jQuery('body').keyup(function (e) {
            if (e.keyCode == 16) {   // 16 = Shift button
                shiftPressed = false;
            }
        });

        jQuery('#FocusBoxLeft h1 a').keydown(function (e) {
            if (e.keyCode == 9 && !shiftPressed) {   // 9 = Tab button
                jQuery(this).parent().parent().find('a.tabLink').addClass('tabLinkFocus'); //.focus();
            }
        });

        jQuery('#FocusBoxLeft a.tabLink').each(function () {
            jQuery(this).parent().find('.FocusBoxLinks a').first().keydown(function(e) {
                if (e.keyCode == 9 && shiftPressed) { // 9 = Tab button
                    jQuery(this).parents('.FocusBoxLinks').parent().find('a.tabLink').addClass('tabLinkFocus'); //.focus();
                }
            });
        });

        jQuery('#FocusBoxLeft a.tabLink').focusout(function () {
            jQuery(this).removeClass('tabLinkFocus');
        });

        jQuery('#FocusBoxLeft a.tabLink').click(function () {
            swapToPlayer(jQuery('.MediaContent a'), jQuery('.MediaContent a').data('objId'), true);
            return false;
        });

        //Add back the mouseover when clicking a link
        jQuery('#FocusBoxLeft > div').bind('click', function (e) {
            jQuery('#FocusBoxLeft > div').bind('mouseover', mouseoverHandler);
            switchTo(jQuery(this));
        });

        //Start rotating images
        showNextImage();
        if (elems.length > 0 && parseInt(getPropertyFromArrayById(elems, elems[0].id, 'delay')) > 0) {
            rotateInterval = window.setInterval(showNextImage, parseInt(getPropertyFromArrayById(elems, elems[0].id, 'delay')) * 1000);

        }
        else {
            //Show the first image
            showNextImage();
        }
    }

    var currentImageIndex = 0;
    var rotateInterval = 0;
    var elems = new Array();
    var shiftPressed = false;

    jQuery(function () {
        init();
    });
//]]>
</script>

