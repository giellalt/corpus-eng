            <h2>
                <a href="/en/dep/ud/about_mfa/organisation/departments/communication_unit.html?id=87123" title="">
                    Communication Unit
                </a>
            </h2>
            <h3 class="subDescription" style="display:none"></h3>
            
            
            
        </div>
    
        <div class="BoxDepartments expDiv">
            
            <h2>
                <a href="/en/dep/ud/about_mfa/organisation/departments/department_european.html?id=1510" title="">
                    Department for European Affairs and Trade Policy
                </a>
            </h2>
            <h3 class="subDescription" style="display:none"></h3>
            
            <p>
                The department is responsible for safeguarding Norway’s interests in European and global cooperation on trade and economic affairs.
            </p>
            
        </div>
    
        <div class="BoxDepartments expDiv">
            
            <h2>
                <a href="/en/dep/ud/about_mfa/organisation/departments/security_policy.html?id=1513" title="">
                    Department for Security Policy and the High North
                </a>
            </h2>
            <h3 class="subDescription" style="display:none"></h3>
            
            <p>
