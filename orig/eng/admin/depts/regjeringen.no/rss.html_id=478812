    $.cookieConsent = function (options) {
        options = $.extend({}, {
            expireDays: 3650,
            messagepart1: "Regjeringen.no uses cookies to improve our service to the users. The cookies are mainly used for traffic measuring and for optimizing the site. Find more information on ",
            messagepart2: ", or go back to regjeringen.no if you accept this.",
            readMoreUrl: "http://www.regjeringen.no/en/Om-nettstedet/personvernpolicy.html?id=650340",
            readMoreLinkText: "use of cookies",
            closeText: "Close"            
        }, options);


        function getCookie(name) {
            var results = document.cookie.match('(^|;) ?' + name + '=([^;]*)(;|$)');
            if (results) return (unescape(results[2]));
            return null;
        }

        function openDialog() {
            var scrollDialogMarkup = '<div id="cookieDialog"><div class="content"><div class="floatRight"><a href="#" class="closeDialog" title="' + options.closeText + '">' + options.closeText + ' X</a></div><div class="info">' + options.messagepart1 + '<a href=" ' + options.readMoreUrl + ' ">' + options.readMoreLinkText + '</a> ' + options.messagepart2 + '</div></div></div>';
            $(scrollDialogMarkup).appendTo('body');

            $('#cookieDialog .closeDialog').click(function () {
                closeCookieInfo();
                return false;
            });

            $('#cookieDialog').addClass('visible');
        }


        function hideDialog() {
            $('#cookieDialog').html('');
        }


        function closeCookieInfo() {
            createCookie("cookieconsent", "true", options.expireDays);
            hideDialog();
        }


        function displayCookieInfoLayer() {
            var cookieconsent = getCookie("cookieconsent");
            var noCockieConsent = (cookieconsent == undefined || cookieconsent != 'true');
            var notInEditMode = (isOpenedInEditMode() === -1);

            if ( noCockieConsent && notInEditMode) {                
                openDialog();

            } else {
                
                hideDialog();
            }
        }

        function createCookie(name,value,days) {
            if (days) {
                var date = new Date();
                date.setTime(date.getTime()+(days*24*60*60*1000));
                var expires = "; expires="+date.toGMTString();
            } else {
                expires = "";
            }            
            document.cookie = name+"="+escape(value)+expires+"; path=/;";
        }


        function isOpenedInEditMode() {                       
            return contains(document.referrer, "/cms/edit/");
        }

       function contains(haystack, needle, caseSensitive) {
            haystack = caseSensitive ? haystack : haystack.toUpperCase();
            needle = caseSensitive ? needle : needle.toUpperCase();            
            return haystack.indexOf(needle);
        }


        displayCookieInfoLayer();
       

    };


    $(function () {
        $.cookieConsent();
       
    });
